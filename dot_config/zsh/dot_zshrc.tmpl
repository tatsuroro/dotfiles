# ============================================================
# skipcd (port of tatsuroro/skipcd.fish)
# ============================================================
skipcd() {
    builtin cd "$@" || return

    IFS=',' read -rA skipcd_repo_paths <<< "$SKIPCD_REPO_PATH"
    IFS=',' read -rA skipcd_subdir_names <<< "$SKIPCD_SUBDIR_NAME"

    local toplevel
    toplevel=$(git rev-parse --show-toplevel 2>/dev/null)

    for repo_path in "${skipcd_repo_paths[@]}"; do
        if [[ "$toplevel" = "$repo_path" ]]; then
            for subdir_name in "${skipcd_subdir_names[@]}"; do
                if [[ -d "$subdir_name" ]]; then
                    builtin cd "$subdir_name"
                    return
                fi
            done
        fi
    done
}

# ============================================================
# bd (port of 0rax/fish-bd)
# ============================================================
bd() {
    local oldpwd=$(pwd)
    local newpwd=""
    local opts="${BD_OPT:-classic}"
    local pattern=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h)
                echo "bd: Quickly go back to a parent directory"
                echo "Usage: bd [option] <pattern>"
                echo "Options: -c classic (default), -s sensitive, -i insensitive, -h help"
                return 0
                ;;
            -s) opts="sensitive"; shift ;;
            -i) opts="insensitive"; shift ;;
            -c) opts="classic"; shift ;;
            *)  pattern="$1"; shift ;;
        esac
    done

    if [[ -z "$pattern" ]]; then
        cd ..
        pwd
        return 0
    fi

    case "$opts" in
        sensitive)
            newpwd=$(echo "$oldpwd" | sed "s|\(.*/${pattern}[^/]*/\).*|\1|")
            ;;
        insensitive)
            newpwd=$(echo "$oldpwd" | perl -pe "s|(.*/${pattern}[^/]*/).*|\$1|i")
            ;;
        *)
            newpwd=$(echo "$oldpwd" | sed "s|\(.*/${pattern}/\).*|\1|")
            ;;
    esac

    if [[ "$newpwd" = "$oldpwd" ]]; then
        echo "No such occurence." >&2
    else
        echo "$newpwd"
        cd "$newpwd"
    fi
}

# ============================================================
# fzf_select_ghq_repository (Ctrl+S)
# ============================================================
fzf_select_ghq_repository() {
    local selected
    selected=$(ghq list | fzf)
    if [[ -n "$selected" ]]; then
        cd "$(ghq root)/$selected"
    fi
    zle reset-prompt
}
zle -N fzf_select_ghq_repository
bindkey '^S' fzf_select_ghq_repository

# ============================================================
# fzf_kill (Ctrl+Q)
# ============================================================
fzf_kill() {
    local pid
    pid=$(ps -ef | sed 1d | fzf -m | awk '{print $2}')
    if [[ -n "$pid" ]]; then
        echo "$pid" | xargs kill -${1:-9}
    fi
    zle reset-prompt
}
zle -N fzf_kill
bindkey '^Q' fzf_kill

